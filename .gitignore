/target
# Cargo.lock should be committed for binary crates
# Cargo.lock
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.env
.idea/
.vscode/
npm/node_modules/
# Prebuilt platform binaries are build artifacts, not source
npm/platforms/**/ctl
npm/platforms/**/ctl.exe
# Canonical ledgers, projections, and the decision log stay local; the spec
# tier (ADRs, PRDs, alignment notes, guides) is committed like code.
/.ctl/*
!/.ctl/spec/
__pycache__/
*.pyc
