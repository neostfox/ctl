{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control.task-view.v1.schema.json",
  "title": "TaskView",
  "description": "Projection of task state generated by replay.",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "control.task-view.v1"
    },
    "id": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": ["planning", "ready", "in_progress", "review", "completed", "cancelled"]
    },
    "is_held": {
      "type": "boolean"
    },
    "is_archived": {
      "type": "boolean"
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "read_scope": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "write_allow": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "write_deny": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_triggers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "gates": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "last_event_seq": {
      "type": "integer"
    }
  },
  "required": [
    "schema",
    "id",
    "phase",
    "is_held",
    "is_archived",
    "objective",
    "read_scope",
    "write_allow",
    "write_deny",
    "risk_triggers",
    "gates",
    "last_event_seq"
  ],
  "unevaluatedProperties": false
}
