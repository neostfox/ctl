{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control.task-view.v1.schema.json",
  "title": "TaskView",
  "description": "Projection of task state generated by replay.",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "control.task-view.v1"
    },
    "id": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": ["planning", "ready", "in_progress", "review", "completed", "cancelled"]
    },
    "is_held": {
      "type": "boolean"
    },
    "objective": {
      "type": "string"
    },
    "gates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "last_event_seq": {
      "type": "integer"
    }
  },
  "required": ["schema", "id", "phase", "is_held", "last_event_seq"],
  "unevaluatedProperties": false
}
