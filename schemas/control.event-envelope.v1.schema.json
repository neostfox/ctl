{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control.event-envelope.v1.schema.json",
  "title": "EventEnvelope",
  "description": "Canonical event envelope for the AI Dev Control Plane.",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "control.event-envelope.v1"
    },
    "event_id": {
      "description": "Unique event identifier (UUIDv4).",
      "type": "string",
      "format": "uuid"
    },
    "command_id": {
      "description": "Idempotent command identifier.",
      "type": "string",
      "format": "uuid"
    },
    "task_id": {
      "description": "Target task identifier.",
      "type": "string"
    },
    "seq": {
      "description": "Strictly increasing sequence number.",
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "description": "ISO 8601 timestamp.",
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "description": "Who triggered the event (human, agent, system).",
      "type": "string"
    },
    "type": {
      "description": "Event type name.",
      "type": "string",
      "enum": [
        "task_created",
        "task_revised",
        "task_marked_ready",
        "task_started",
        "task_submitted_for_review",
        "task_reopened",
        "task_completed",
        "task_cancelled",
        "task_archived",
        "hold_entered",
        "hold_exited",
        "boundary_violation_recorded",
        "gate_checked",
        "evidence_accepted",
        "evidence_rejected",
        "workspace_created",
        "workspace_cleaned",
        "workspace_diff_computed",
        "workspace_applied",
        "run_started",
        "run_completed",
        "run_failed",
        "lease_created",
        "lease_used",
        "lease_expired",
        "lease_revoked",
        "approval_requested",
        "approval_granted",
        "approval_denied",
        "approval_expired",
        "run_scheduled",
        "run_launched",
        "run_merged",
        "run_created",
        "run_finished",
        "run_aborted",
        "brainstorm_artifact_recorded",
        "critic_artifact_attached",
        "brainstorm_skipped",
        "uncertainty_recorded",
        "uncertainty_disposition_recorded",
        "evidence_recorded",
        "research_artifact_recorded",
        "subagent_dispatched"
      ]
    },
    "payload": {
      "description": "Event-specific payload.",
      "type": "object"
    }
  },
  "required": [
    "schema",
    "event_id",
    "command_id",
    "task_id",
    "seq",
    "occurred_at",
    "actor",
    "type",
    "payload"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "const": "gate_checked" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["gate_id", "passed", "evidence", "checked_at"],
            "properties": {
              "gate_id": {
                "description": "Identifier of the gate that was checked.",
                "type": "string",
                "minLength": 1
              },
              "passed": {
                "description": "Whether the gate passed.",
                "type": "boolean"
              },
              "evidence": {
                "description": "Human-readable evidence of the gate result.",
                "type": "string",
                "minLength": 1
              },
              "checked_at": {
                "description": "ISO 8601 timestamp of when the gate was checked.",
                "type": "string",
                "format": "date-time"
              },
              "tree_hash": {
                "description": "Git tree hash (HEAD^{tree}) this gate result was validated against (artifact binding). Optional for legacy events recorded before binding existed.",
                "type": "string",
                "minLength": 1
              },
              "policy_hash": {
                "description": "Canonical policy hash in force when this gate ran (policy binding). Optional for legacy events recorded before binding existed.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_revised" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "objective",
              "read_scope",
              "write_allow",
              "write_deny",
              "risk_triggers",
              "gates"
            ],
            "properties": {
              "objective": {
                "description": "Updated objective.",
                "type": "string",
                "minLength": 1
              },
              "read_scope": {
                "description": "Updated files/dirs allowed to read.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_allow": {
                "description": "Updated files/dirs allowed to modify.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_deny": {
                "description": "Updated explicitly denied files/dirs.",
                "type": "array",
                "items": { "type": "string" }
              },
              "risk_triggers": {
                "description": "Updated conditions that trigger hold.",
                "type": "array",
                "items": { "type": "string" }
              },
              "gates": {
                "description": "Updated gate list.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "depends_on": {
                "description": "Task IDs that must complete before this task can run (declared dependency edges, M-d). Optional; absent means no dependencies.",
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_created" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "objective",
              "read_scope",
              "write_allow",
              "write_deny",
              "risk_triggers",
              "gates"
            ],
            "properties": {
              "objective": {
                "description": "Task objective.",
                "type": "string",
                "minLength": 1
              },
              "read_scope": {
                "description": "Files/dirs allowed to read.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_allow": {
                "description": "Files/dirs allowed to modify.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_deny": {
                "description": "Explicitly denied files/dirs.",
                "type": "array",
                "items": { "type": "string" }
              },
              "risk_triggers": {
                "description": "Conditions that trigger hold.",
                "type": "array",
                "items": { "type": "string" }
              },
              "gates": {
                "description": "Required gate IDs.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "depends_on": {
                "description": "Task IDs that must complete before this task can run (declared dependency edges, M-d). Optional; absent means no dependencies.",
                "type": "array",
                "items": { "type": "string" }
              },
              "task_kind": {
                "description": "Research/Spike V1: task kind. Optional; absent means implementation (legacy default). Fixed at creation, never revised.",
                "type": "string",
                "enum": ["implementation", "research"]
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_marked_ready" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_started" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_submitted_for_review" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_reopened" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_completed" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_cancelled" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_archived" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "hold_entered" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "reason": {
                "description": "Optional human-readable hold reason.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "hold_exited" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "boundary_violation_recorded" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "violation": {
                "description": "Description of the boundary violation.",
                "type": "string",
                "minLength": 1
              },
              "detected_at": {
                "description": "ISO 8601 timestamp when the violation was detected.",
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["violation"],
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "evidence_accepted" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["evidence_id", "source", "touched_files"],
            "properties": {
              "evidence_id": {
                "description": "Unique evidence identifier.",
                "type": "string",
                "minLength": 1
              },
              "source": {
                "description": "Evidence source adapter.",
                "type": "string",
                "minLength": 1
              },
              "touched_files": {
                "description": "Files reported as touched.",
                "type": "array",
                "items": { "type": "string" }
              },
              "result_file": {
                "description": "Path to the submitted result file.",
                "type": "string"
              },
              "accepted_at": {
                "description": "ISO 8601 timestamp of acceptance.",
                "type": "string"
              },
              "tree_hash": {
                "description": "Git tree hash (HEAD^{tree}) this completion audit validated against (artifact binding). Optional for legacy events recorded before binding existed.",
                "type": "string",
                "minLength": 1
              },
              "policy_hash": {
                "description": "Canonical policy hash this completion audit validated against (policy binding). Optional for legacy events recorded before binding existed.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "evidence_rejected" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["evidence_id"],
            "properties": {
              "evidence_id": {
                "description": "Unique evidence identifier.",
                "type": "string"
              },
              "source": {
                "description": "Evidence source adapter.",
                "type": "string"
              },
              "rejection_reason": {
                "description": "Why the evidence was rejected.",
                "type": "string"
              },
              "touched_file": {
                "description": "The offending file path.",
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "workspace_created" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["worktree_path", "branch"],
            "properties": {
              "worktree_path": {
                "description": "Path to the created git worktree.",
                "type": "string",
                "minLength": 1
              },
              "branch": {
                "description": "Branch name used for the worktree.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "workspace_cleaned" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["worktree_path"],
            "properties": {
              "worktree_path": {
                "description": "Path to the cleaned worktree.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "workspace_diff_computed" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["files_added", "files_modified", "files_deleted", "high_risk"],
            "properties": {
              "files_added": {
                "description": "Files added in worktree.",
                "type": "array",
                "items": { "type": "string" }
              },
              "files_modified": {
                "description": "Files modified in worktree.",
                "type": "array",
                "items": { "type": "string" }
              },
              "files_deleted": {
                "description": "Files deleted in worktree.",
                "type": "array",
                "items": { "type": "string" }
              },
              "high_risk": {
                "description": "High-risk change descriptions.",
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "workspace_applied" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["files_applied"],
            "properties": {
              "files_applied": {
                "description": "Files applied from worktree to main workspace.",
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "run_started" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["run_id", "adapter", "lease_id"],
            "properties": {
              "run_id": {
                "description": "Unique run identifier.",
                "type": "string",
                "minLength": 1
              },
              "adapter": {
                "description": "Adapter name (e.g., 'omp').",
                "type": "string",
                "minLength": 1
              },
              "lease_id": {
                "description": "Capability lease bound to this run.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "run_completed" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["run_id"],
            "properties": {
              "run_id": {
                "description": "Unique run identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "run_failed" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["run_id", "reason"],
            "properties": {
              "run_id": {
                "description": "Unique run identifier.",
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "description": "Failure reason.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "lease_created" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["lease_id", "run_id", "resource_path", "action", "ttl_seconds", "max_uses"],
            "properties": {
              "lease_id": {
                "description": "Unique lease identifier.",
                "type": "string",
                "minLength": 1
              },
              "run_id": {
                "description": "Run this lease is bound to.",
                "type": "string",
                "minLength": 1
              },
              "resource_path": {
                "description": "Resource path the lease grants access to.",
                "type": "string",
                "minLength": 1
              },
              "action": {
                "description": "Action type (read/write).",
                "type": "string",
                "minLength": 1
              },
              "ttl_seconds": {
                "description": "Time-to-live in seconds.",
                "type": "integer",
                "minimum": 1
              },
              "max_uses": {
                "description": "Maximum number of uses.",
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "lease_used" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["lease_id"],
            "properties": {
              "lease_id": {
                "description": "Lease identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "lease_expired" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["lease_id", "reason"],
            "properties": {
              "lease_id": {
                "description": "Lease identifier.",
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "description": "Expiration reason (ttl or max_uses).",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "lease_revoked" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["lease_id"],
            "properties": {
              "lease_id": {
                "description": "Lease identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "approval_requested" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["request_id", "reason", "scope", "ttl_seconds"],
            "properties": {
              "request_id": {
                "description": "Unique approval request identifier.",
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "description": "Structured reason for the approval request.",
                "type": "string",
                "minLength": 1
              },
              "scope": {
                "description": "JSON scope describing affected files/changes.",
                "type": "object"
              },
              "ttl_seconds": {
                "description": "Time-to-live in seconds before auto-expiry.",
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "approval_granted" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["request_id"],
            "properties": {
              "request_id": {
                "description": "Approval request identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "approval_denied" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["request_id"],
            "properties": {
              "request_id": {
                "description": "Approval request identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "approval_expired" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["request_id"],
            "properties": {
              "request_id": {
                "description": "Approval request identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "run_scheduled" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["plan_id"],
            "properties": {
              "plan_id": {
                "description": "Schedule plan identifier.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "run_launched" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["run_id", "worktree_path", "lease_id"],
            "properties": {
              "run_id": {
                "description": "Agent run identifier.",
