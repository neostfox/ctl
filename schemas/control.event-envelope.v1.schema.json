{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control.event-envelope.v1.schema.json",
  "title": "EventEnvelope",
  "description": "Canonical event envelope for the AI Dev Control Plane.",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "control.event-envelope.v1"
    },
    "event_id": {
      "description": "Unique event identifier (UUIDv4).",
      "type": "string",
      "format": "uuid"
    },
    "command_id": {
      "description": "Idempotent command identifier.",
      "type": "string",
      "format": "uuid"
    },
    "task_id": {
      "description": "Target task identifier.",
      "type": "string"
    },
    "seq": {
      "description": "Strictly increasing sequence number.",
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "description": "ISO 8601 timestamp.",
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "description": "Who triggered the event (human, agent, system).",
      "type": "string"
    },
    "type": {
      "description": "Event type name.",
      "type": "string",
      "enum": [
        "task_created",
        "task_revised",
        "task_marked_ready",
        "task_started",
        "task_submitted_for_review",
        "task_reopened",
        "task_completed",
        "task_cancelled",
        "task_archived",
        "hold_entered",
        "hold_exited",
        "boundary_violation_recorded",
        "gate_checked"
      ]
    },
    "payload": {
      "description": "Event-specific payload.",
      "type": "object"
    }
  },
  "required": [
    "schema",
    "event_id",
    "command_id",
    "task_id",
    "seq",
    "occurred_at",
    "actor",
    "type",
    "payload"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "const": "gate_checked" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["gate_id", "passed", "evidence", "checked_at"],
            "properties": {
              "gate_id": {
                "description": "Identifier of the gate that was checked.",
                "type": "string",
                "minLength": 1
              },
              "passed": {
                "description": "Whether the gate passed.",
                "type": "boolean"
              },
              "evidence": {
                "description": "Human-readable evidence of the gate result.",
                "type": "string",
                "minLength": 1
              },
              "checked_at": {
                "description": "ISO 8601 timestamp of when the gate was checked.",
                "type": "string",
                "format": "date-time"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_revised" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "objective",
              "read_scope",
              "write_allow",
              "write_deny",
              "risk_triggers",
              "gates"
            ],
            "properties": {
              "objective": {
                "description": "Updated objective.",
                "type": "string",
                "minLength": 1
              },
              "read_scope": {
                "description": "Updated files/dirs allowed to read.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_allow": {
                "description": "Updated files/dirs allowed to modify.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_deny": {
                "description": "Updated explicitly denied files/dirs.",
                "type": "array",
                "items": { "type": "string" }
              },
              "risk_triggers": {
                "description": "Updated conditions that trigger hold.",
                "type": "array",
                "items": { "type": "string" }
              },
              "gates": {
                "description": "Updated gate list.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_created" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "objective",
              "read_scope",
              "write_allow",
              "write_deny",
              "risk_triggers",
              "gates"
            ],
            "properties": {
              "objective": {
                "description": "Task objective.",
                "type": "string",
                "minLength": 1
              },
              "read_scope": {
                "description": "Files/dirs allowed to read.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_allow": {
                "description": "Files/dirs allowed to modify.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              },
              "write_deny": {
                "description": "Explicitly denied files/dirs.",
                "type": "array",
                "items": { "type": "string" }
              },
              "risk_triggers": {
                "description": "Conditions that trigger hold.",
                "type": "array",
                "items": { "type": "string" }
              },
              "gates": {
                "description": "Required gate IDs.",
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_marked_ready" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_started" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_submitted_for_review" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_reopened" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_completed" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_cancelled" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "task_archived" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "hold_entered" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "reason": {
                "description": "Optional human-readable hold reason.",
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "hold_exited" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "boundary_violation_recorded" }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "violation": {
                "description": "Description of the boundary violation.",
                "type": "string",
                "minLength": 1
              },
              "detected_at": {
                "description": "ISO 8601 timestamp when the violation was detected.",
                "type": "string",
                "minLength": 1
              }
            },
            "required": ["violation"],
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
